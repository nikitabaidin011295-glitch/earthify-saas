# DATABASE — Railway надає автоматично через ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://user:password@host:5432/earthify"

# REDIS — Railway надає автоматично через ${{Redis.REDIS_URL}}
REDIS_URL="redis://default:password@host:6379"

# JWT (мінімум 32 символи кожен)
JWT_SECRET="earthify-super-secret-jwt-key-minimum-32-chars-here"
JWT_REFRESH_SECRET="earthify-refresh-secret-key-minimum-32-chars-here"

# CORS — домен твого Vercel фронтенду
CORS_ORIGIN="https://your-app.vercel.app"

# APP URLs
API_URL="https://your-api.up.railway.app"
ADMIN_APP_URL="https://your-app.vercel.app"
NODE_ENV=production

# LIQPAY (опційно)
LIQPAY_PUBLIC_KEY=""
LIQPAY_PRIVATE_KEY=""

# TELEGRAM (опційно)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""

# META Instagram/Facebook (опційно)
META_APP_ID=""
META_APP_SECRET=""
META_VERIFY_TOKEN=""

# VIBER (опційно)
VIBER_AUTH_TOKEN=""
